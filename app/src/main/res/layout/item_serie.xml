<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout de UM item da lista (o card amarelo da imagem).
    Esse arquivo é "inflado" pelo Adapter uma vez para cada linha.
    Estrutura:
      - Linha de cima: Nome (esquerda)  ........  id (direita)
      - data
      - episódio
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_item_amarelo"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Linha superior: Nome à esquerda, id à direita -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvNome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="Nome"
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="id"
            android:textColor="@android:color/black"
            android:textSize="16sp" />
    </RelativeLayout>

    <TextView
        android:id="@+id/tvData"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="data"
        android:textColor="@android:color/black"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvEpisodio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="episódio"
        android:textColor="@android:color/black"
        android:textSize="16sp" />

</LinearLayout>